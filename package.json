{
  "name": "config-manager-api",
  "version": "1.0.0",
  "description": "REST API for ConfigManager - Configuration management with real-time updates",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pino": "^9.10.0",
    "pino-pretty": "^13.1.1",
    "pino-seq": "^2.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  },
  "keywords": [
    "redis",
    "config",
    "configuration",
    "management",
    "api",
    "real-time",
    "microservices"
  ],
  "author": "",
  "license": "MIT"
}
